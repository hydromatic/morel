# morel> it = 8;

# Print usage
usage() {
  cd $(dirname $0)
  head -1 ./README
  echo "Usage: morel [command] [option...] [file...]"
  echo
  echo "Commands:"
  echo "  execute             Run script or REPL (default if no command given)."
  echo "  darn-update         Execute <!-- morel --> cells and update files in-place."
  echo "  darn-verify         Verify <!-- morel --> cells; report mismatches."
  echo "  darn-probe          Probe skip cells: try executing each, report OK/ERROR."
  echo
  echo "Options (execute):"
  echo "  --build             Compile the source code first."
  echo "  --echo              Send script output stdout as well as file."
  echo "  -e, --eval <expr>   Evaluate expression and exit."
  echo "  -h, --help          Print this help, then exit."
  echo "  --idempotent        Treat all files (and stdin) as SMLI format."
  echo "                      Set implicitly if the first file has suffix '.smli'."
  echo "  --no-build          Don't compile the source code first. (This is the"
  echo "                      default, but a limited build will always occur if"
  echo "                      'target/classpath.txt' is not present.)"
  echo
  echo "Options (all commands):"
  echo "  --foreign=CLASS     Load foreign dataset from Java class."
  echo
  echo "Cell syntax (inside <!-- morel ... --> comments):"
  echo "  Commands (mutually exclusive; default is 'run'):"
  echo "    run               Execute code and show div with input and output."
  echo "    silent            Execute code but show no div."
  echo "    skip              Show div but do not execute."
  echo "  Options:"
  echo "    output / no-output  Include or suppress the output block (default: output)."
  echo "    fail / no-fail      Expect execution to produce an error (default: no-fail)."
  echo "    env=NAME            Share kernel state with other cells of the same name."
}

# Detect sub-command: first arg if it is a known sub-command name.
SUBCMD=execute
case "$1" in
  (execute|darn-update|darn-verify|darn-probe)
    SUBCMD="$1"
    shift
    ;;
esac

# Process options.
BUILD=
HELP=
EVAL_EXPR=
ECHO=
FOREIGN=
FILES=()
while [ $# -gt 0 ]; do
  case "$1" in
    (--help|-h)
      HELP=true
      shift
      ;;
    (--no-build)
      BUILD=
      shift
      ;;
    (--build)
      BUILD=true
      shift
      ;;
    (--echo)
      ECHO=true
      shift
      ;;
    (-e|--eval)
      EVAL_EXPR="$2"
      shift 2
      ;;
    (--eval=*)
      EVAL_EXPR="${1#--eval=}"
      shift
      ;;
    (--idempotent)
      SUBCMD=smli
      shift
      ;;
    (--foreign=*)
      FOREIGN="$FOREIGN $1"
      shift
      ;;
    (*.smli)
      if [ ${#FILES[@]} -eq 0 ] && [ "$SUBCMD" = "execute" ]; then
        SUBCMD=smli
      fi
      FILES+=("$1")
      shift
      ;;
    (*)
      FILES+=("$1")
      shift
      ;;
  esac
done

if [ "$HELP" ]; then
  usage
  exit 1
fi

# Deduce whether we are running cygwin
case $(uname -s) in
(CYGWIN*) cygwin=true;;
(*) cygwin=;;
esac

# Build classpath on first call.
# (To force rebuild, remove target/classpath.txt, or just "./mvnw clean".)
cd "$(dirname "$0")" || exit
if [ "$BUILD" ]; then
    ./mvnw \
        dependency:build-classpath -Dmdep.outputFile=target/classpath.txt \
        compile test-compile
elif [ ! -f target/classpath.txt ]; then
    ./mvnw -DskipTests \
        dependency:build-classpath -Dmdep.outputFile=target/classpath.txt \
        compile test-compile
fi

CP="target/classes:\
target/test-classes:\
$(cat target/classpath.txt)"

VM_OPTS=
if [ "$cygwin" ]; then
  CP=$(cygpath -wp "$CP")

  # Work around https://github.com/jline/jline2/issues/62
  VM_OPTS=-Djline.terminal=jline.UnixTerminal
fi

export JAVA_OPTS=-Djavax.xml.parsers.DocumentBuilderFactory=com.sun.org.apache.xerces.internal.jaxp.DocumentBuilderFactoryImpl

# Default foreign dataset for all modes.
DEFAULT_FOREIGN="--foreign=net.hydromatic.morel.BuiltInDataSet\$Dictionary"

# In a headless environment (stdin is not a terminal), run the Shell in dumb
# terminal mode so jline does not try to create an interactive terminal.
HEADLESS_OPTS=
if [ ! -t 0 ]; then
  HEADLESS_OPTS="--terminal=dumb --banner=false"
fi

case "$SUBCMD" in
  (smli)
    if [ ${#FILES[@]} -eq 0 ]; then
      FILES=(-)
    fi
    exec java $VM_OPTS -cp "${CP}" $JAVA_OPTS net.hydromatic.morel.Script \
        $(if [ "$ECHO" ]; then echo --echo; fi) \
        --directory="$(pwd)" \
        "${FILES[@]}"
    ;;
  (darn-update|darn-verify|darn-probe)
    exec java $VM_OPTS -cp "${CP}" $JAVA_OPTS net.hydromatic.morel.Main \
        "$SUBCMD" \
        "$DEFAULT_FOREIGN" \
        $FOREIGN \
        "${FILES[@]}"
    ;;
  (execute)
    if [ -n "$EVAL_EXPR" ]; then
      exec java $VM_OPTS -cp "${CP}" $JAVA_OPTS net.hydromatic.morel.Shell \
           "$DEFAULT_FOREIGN" \
           $FOREIGN \
           --directory="$(pwd)" \
           --terminal=dumb \
           --banner=false \
           -e "$EVAL_EXPR"
    else
      exec java $VM_OPTS -cp "${CP}" $JAVA_OPTS net.hydromatic.morel.Shell \
           "$DEFAULT_FOREIGN" \
           $FOREIGN \
           --directory="$(pwd)" \
           $HEADLESS_OPTS \
           "${FILES[@]}"
    fi
    ;;
esac

# End morel
