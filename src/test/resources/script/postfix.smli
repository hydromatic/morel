Sys.set ("lineWidth", 78);
> val it = () : unit

(* Field projection still works with structures (backward compatible) *)
String.size "abc";
> val it = 3 : int

(* Field projection still works with record values *)
val r = {name = "alice", age = 30};
> val r = {age=30,name="alice"} : {age:int, name:string}

r.name;
> val it = "alice" : string

r.age;
> val it = 30 : int

(* Atom-arg form works with bound variables (not just with literals).
   These exercise the case where the receiver is a bare identifier that
   refers to a non-record value, not a module/structure. *)
val xs = [3, 1, 4, 1, 5];
> val xs = [3,1,4,1,5] : int list
xs.drop 2;
> val it = [4,1,5] : int list
xs.drop(2).drop 1;
> val it = [1,5] : int list

xs.length ();
> val it = 5 : int
xs.drop(1).length ();
> val it = 4 : int

val s = "hello";
> val s = "hello" : string
s.sub 1;
> val it = #"e" : char

val n = 4;
> val n = 4 : int
n.compare 3;
> val it = GREATER : order

(SOME 5).getOpt(0).compare(3);
> val it = GREATER : order
NONE.getOpt(0).compare(3);
> val it = LESS : order
(SOME #"a").getOpt(#"p").compare(#"g");
> val it = LESS : order
fun f (x: int option) = x.getOpt(0).compare(3);
> val f = fn : int option -> order
f (SOME 5);
> val it = GREATER : order
f (SOME ~5);
> val it = LESS : order
f NONE;
> val it = LESS : order

val r = {i = 1, n};
> val r = {i=1,n=4} : {i:int, n:int}
r.i.compare (r.n);
> val it = LESS : order
r.n.compare 3;
> val it = GREATER : order

(* When the receiver is a field access (e.ename), the receiver is not
   a bare identifier, and atom-arg postfix works correctly. *)
from e in [{ename = "alice"}, {ename = "bob"}]
yield {size = e.ename.size (), initial = e.ename.sub 0};
> val it = [{initial=#"a",size=5},{initial=#"b",size=3}]
>   : {initial:char, size:int} list

(* User-defined postfix functions work when the function definition and call
   site are in the same TypeResolver scope (e.g. the same let expression).
   Limitation: a function defined at the top level in a previous statement is
   not visible to the postfix interceptor in a later statement, because each
   statement is resolved independently. *)
let
  fun greet self = "Hello, " ^ self
in
  "world".greet ()
end;
> val it = "Hello, world" : string

(* User-defined function with self as first element of a tuple. *)
let
  fun pad (self : string, width : int) =
      let val n = String.size self
      in if n >= width then self
         else self ^ String.implode (List.tabulate (width - n, fn _ => #" "))
      end
in
  "hi".pad 5
end;
> val it = "hi   " : string

(* Disambiguation between functions with the same name in different structures.
   Six names are shared between Int and Real: abs, max, min, rem, sign,
   toString. Bool and Char also have toString.
   Disambiguation uses the receiver's type, resolved via the type constraint
   chain (termOperatorOf follows variable-to-variable links so that bound
   identifiers like 'r' are correctly resolved to their concrete type). *)

(* Int.abs vs Real.abs — literal receivers *)
(~3).abs ();
> val it = 3 : int

(~3.0).abs ();
> val it = 3 : real

(* Int.abs vs Real.abs — bound-variable receivers *)
let val n = ~3   in n.abs () end;
> val it = 3 : int

let val r = ~3.0 in r.abs () end;
> val it = 3 : real

(* Int.max vs Real.max — tuple-splicing form *)
(4).max 3;
> val it = 4 : int

(4.0).max 3.0;
> val it = 4 : real

(* Int.min vs Real.min *)
(4).min 3;
> val it = 3 : int

(4.0).min 3.0;
> val it = 3 : real

(* Int.rem vs Real.rem *)
(14).rem 3;
> val it = 2 : int

(14.0).rem 3.0;
> val it = 2 : real

(* Int.sign vs Real.sign *)
(~5).sign ();
> val it = ~1 : int

(~2.5).sign ();
> val it = ~1 : int

(* toString — four candidates: Bool, Char, Int, Real *)
true.toString ();
> val it = "true" : string

(#"A").toString ();
> val it = "A" : string

(42).toString ();
> val it = "42" : string

(3.14).toString ();
> val it = "3.14" : string

(* Bound-variable receivers for toString *)
let val b = true   in b.toString () end;
> val it = "true" : string

let val c = #"A"   in c.toString () end;
> val it = "A" : string

let val n = 42     in n.toString () end;
> val it = "42" : string

let val r = 3.14   in r.toString () end;
> val it = "3.14" : string

(* The following would work if the limitation were lifted: a top-level
   function definition followed by a postfix call in a separate statement.
fun greet self = "Hello, " ^ self;
> val greet = fn : string -> string
"world".greet ();
> val it = "Hello, world" : string
*)

(* The safe-navigation operator "?." projects a field through the receiver's
 * functor (option, list, bag, or vector). *)

(*) Projecting a field of an option.
(SOME {a=1, b=2})?.b;
> val it = SOME 2 : int option
(NONE : {a:int, b:int} option)?.b;
> val it = NONE : int option

(*) Projecting a field of a list (equivalent to "from e in es yield e.a").
[{a=1},{a=2},{a=3}]?.a;
> val it = [1,2,3] : int list

(*) Chaining "?." through nested records.
let val z = SOME {b={c={d=42}}} in z?.b?.c?.d end;
> val it = SOME 42 : int option
[{b={c=1}},{b={c=2}}]?.b?.c;
> val it = [1,2] : int list

(* "?." preserves the field's own type. If the field is itself option-typed,
 * the result keeps both layers: "int option option", not "int option". *)
let val z = SOME {b = SOME {c=5}} in z?.b?.c end;
> val it = SOME (SOME 5) : int option option
let val z : {b:{c:int} option} option = NONE in z?.b?.c end;
> val it = NONE : int option option

(* "?." tunnels through multiple functor layers in the receiver to reach the
 * record, then re-wraps the field in those layers. *)
let val x = SOME (SOME {y=7}) in x?.y end;
> val it = SOME (SOME 7) : int option option
let val xs = [SOME {a=1}, NONE] in xs?.a end;
> val it = [SOME 1,NONE] : int option list

(* The layers may be any mix of functors; "?." reconstructs the exact stack
 * (each layer with its own functor), replacing the record with the field. *)
(SOME [SOME {y=1}, NONE, SOME {y=3}])?.y;
> val it = SOME [SOME 1,NONE,SOME 3] : int option list option
[[{y=1},{y=2}],[{y=3}]]?.y;
> val it = [[1,2],[3]] : int list list
(SOME [{y=1},{y=2}])?.y;
> val it = SOME [1,2] : int list option

(*) "?." works over bag and vector, and mixes them with option and list.
(Bag.fromList [{y=1},{y=2},{y=3}])?.y;
> val it = [1,2,3] : int bag
(Vector.fromList [{y=1},{y=2}])?.y;
> val it = #[1,2] : int vector
(SOME (Bag.fromList [{y=1},{y=2}]))?.y;
> val it = SOME ([1,2]) : int bag option
(Bag.fromList [SOME {y=1}, NONE])?.y;
> val it = [SOME 1,NONE] : int option bag

(*) Receiver type comes from a query rather than an annotation.
from x in [SOME {a=10}, NONE] yield x?.a;
> val it = [SOME 10,NONE] : int option list

(*) Receiver is not a functor.
let val n = 5 in n?.x end;
> stdIn:1.18 Error: '?.' applied to non-functor type int (expected option or list)
>   raised at: stdIn:1.18

(*) Functor whose innermost type is not a record.
(SOME 1)?.a;
> stdIn:1.2-1.8 Error: reference to field a of non-record type int
>   raised at: stdIn:1.2-1.8

(*) Record, but no such field.
(SOME {a=1})?.b;
> stdIn:1.15 Error: no field 'b' in type '{a:int}'
>   raised at: stdIn:1.15

(* Tunneling reaches a non-record type: "w?.b" is "int list option", and so
 * "?.c" tunnels through both layers to "int", which has no fields. *)
let val w : {b:int list} option = NONE in w?.b?.c end;
> stdIn:1.43-1.47 Error: reference to field c of non-record type int
>   raised at: stdIn:1.43-1.47

(*) End postfix.smli
