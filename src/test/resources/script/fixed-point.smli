(* 5. Barbell --------------------------------------------------------
 * In Datalog:
 *    Barbell(x, y, z, x', y', z') :-
 *            R(x, y), S(y, z), T(x, z),
 *            U(x, x'),
 *            R'(x', y'), S'(y', z'), T'(x', z').
 *)

(* TODO enable when there is an efficient implementation
from x, y, z, x', y', z'
  where (x, y) elem western_pairs
    andalso (y, z) elem western_pairs
    andalso (x, z) elem western_pairs
    andalso (x, x') elem western_pairs
    andalso (x', y') elem western_pairs
    andalso (y', z') elem western_pairs
    andalso (x', z') elem western_pairs;
*)

(* The following query is more efficient because it covers just the
 * nine western states, because it drives from the pair-lists rather
 * than unqualified variables, and because we add conditions like
 * "x < x'" to orient the bridge and the two triangles.
 *
 * The western states graph is densely connected — 9 states, 10
 * distinct triangles — so there are many vertex-disjoint triangle
 * pairs linked by a bridge edge. NV is the most active bridge vertex,
 * appearing in 19 of the 35 rows, because it sits at the junction of
 * the AZ/CA/UT/CO cluster and the ID/OR cluster. *)
from (x, x') in western_pairs,
    (y, z) in western_pairs,
    (y', z') in western_pairs
  where x < x'
    andalso y < z
    andalso y' < z'
    andalso (x, y) elem western_pairs
    andalso (x, z) elem western_pairs
    andalso (x', y') elem western_pairs
    andalso (x', z') elem western_pairs
    andalso x <> y' andalso x <> z'
    andalso y <> x' andalso y <> y' andalso y <> z'
    andalso z <> x' andalso z <> y' andalso z <> z'
  order (x, x', y, y', z, z');
> val it =
>   [{x="AZ",x'="CA",y="CO",y'="NV",z="NM",z'="OR"},
>    {x="AZ",x'="CA",y="CO",y'="NV",z="UT",z'="OR"},
>    {x="AZ",x'="CA",y="NM",y'="NV",z="UT",z'="OR"},
>    {x="AZ",x'="CO",y="CA",y'="NM",z="NV",z'="UT"},
>    {x="AZ",x'="NM",y="CA",y'="CO",z="NV",z'="UT"},
>    {x="AZ",x'="NV",y="CO",y'="CA",z="NM",z'="OR"},
>    {x="AZ",x'="NV",y="CO",y'="CA",z="UT",z'="OR"},
>    {x="AZ",x'="NV",y="CO",y'="ID",z="NM",z'="OR"},
>    {x="AZ",x'="NV",y="CO",y'="ID",z="NM",z'="UT"},
>    {x="AZ",x'="NV",y="CO",y'="ID",z="UT",z'="OR"},
>    {x="AZ",x'="NV",y="NM",y'="CA",z="UT",z'="OR"},
>    {x="AZ",x'="NV",y="NM",y'="ID",z="UT",z'="OR"},
>    {x="AZ",x'="UT",y="CA",y'="CO",z="NV",z'="NM"},
>    {x="AZ",x'="UT",y="CO",y'="ID",z="NM",z'="NV"},
>    {x="CA",x'="OR",y="AZ",y'="ID",z="NV",z'="WA"},
>    {x="CO",x'="UT",y="AZ",y'="ID",z="NM",z'="NV"},
>    {x="ID",x'="NV",y="OR",y'="AZ",z="WA",z'="CA"},
>    {x="ID",x'="NV",y="OR",y'="AZ",z="WA",z'="UT"},
>    {x="ID",x'="UT",y="NV",y'="AZ",z="OR",z'="CO"},
>    {x="ID",x'="UT",y="NV",y'="AZ",z="OR",z'="NM"},
>    {x="ID",x'="UT",y="NV",y'="CO",z="OR",z'="NM"},
>    {x="ID",x'="UT",y="OR",y'="AZ",z="WA",z'="CO"},
>    {x="ID",x'="UT",y="OR",y'="AZ",z="WA",z'="NM"},
>    {x="ID",x'="UT",y="OR",y'="AZ",z="WA",z'="NV"},
>    {x="ID",x'="UT",y="OR",y'="CO",z="WA",z'="NM"},
>    {x="NM",x'="UT",y="AZ",y'="ID",z="CO",z'="NV"},
>    {x="NV",x'="OR",y="AZ",y'="ID",z="CA",z'="WA"},
>    {x="NV",x'="OR",y="AZ",y'="ID",z="UT",z'="WA"},
>    {x="NV",x'="UT",y="AZ",y'="CO",z="CA",z'="NM"},
>    {x="NV",x'="UT",y="CA",y'="AZ",z="OR",z'="CO"},
>    {x="NV",x'="UT",y="CA",y'="AZ",z="OR",z'="NM"},
>    {x="NV",x'="UT",y="CA",y'="CO",z="OR",z'="NM"},
>    {x="NV",x'="UT",y="ID",y'="AZ",z="OR",z'="CO"},
>    {x="NV",x'="UT",y="ID",y'="AZ",z="OR",z'="NM"},
>    {x="NV",x'="UT",y="ID",y'="CO",z="OR",z'="NM"}]
>   : {x:string, x':string, y:string, y':string, z:string, z':string} list

(* 6. PageRank -------------------------------------------------------
 * In Datalog:
 *   PageRank  N(; w: int) :- Edge(x, y); w=<<COUNT(x)>>.
 *   PageRank(x; y: float) :- Edge(x, z); y = 1 / N.
 *   PageRank(x; y: float)*[i=5] :- Edge(x, z), PageRank(z), InvDeg(z);
 *       y = 0.15 + 0.85 * << SUM(z)>>.
 *)

(* Applied to western states (9 nodes, 34 directed edges), 10
 * iterations, damping factor d=0.85. *)
let
  val n = real (List.length western_states)
  val d = 0.85
  val out_deg =
    from (x, y) in western_pairs
      group x compute {deg = count over ()}
  fun step pr =
      from p in pr,
          q in out_deg,
          (a, v) in western_pairs
        where q.x = p.state andalso a = p.state
        group {state = v}
          compute {rank = (1.0 - d) / n
                          + d * sum over (p.rank / real q.deg : real)}
  fun loop 0 pr = pr
    | loop k pr = loop (k - 1) (step pr)
  val init = from s in western_states yield {state = s, rank = 1.0 / n}
in
  from r in loop 10 init order r.state
end;
> val it =
>   [{rank=0.14123239,state="AZ"},{rank=0.09016462,state="CA"},
>    {rank=0.09019309,state="CO"},{rank=0.11877356,state="ID"},
>    {rank=0.09019309,state="NM"},{rank=0.14095598,state="NV"},
>    {rank=0.12006924,state="OR"},{rank=0.14098151,state="UT"},
>    {rank=0.06743651,state="WA"}] : {rank:real, state:string} list

(* 7. Single-Source Shortest Paths (SSSP) ----------------------------
 * In Datalog:
 *   SSSP(x; y: int) :- Edge("start", x); y = 1.
 *   SSSP(x; y: int)* :- Edge(w, x), SSSP(w); y = <<MIN(w)>> + 1.
 * BFS from "CA" using fixp: shortest hop count to each reachable
 * state.
 *)
let
  val source = "CA"
  fun step d =
    let
      val extended =
        from {node = n, dist = di} in d,
             (x, y) in pairs
          where x = n
          yield {node = y, dist = di + 1}
      val d2 =
        from p in d union extended
          group p.node compute {dist = min over p.dist}
    in
      from r in d2 order r.node
    end
in
  fixp step [{node = source, dist = 0}]
end;
