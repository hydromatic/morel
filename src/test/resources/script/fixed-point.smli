(* 2. Count Triangles ------------------------------------------------
 * In Datalog:
 *   CountTriangle(; w: long) :-
 *       R(x, y), S(y, z), T(z, x); w=<<COUNT(*)>>.
 * (The formula in the EmptyHeaded paper contains an error.)
 *)

from x, y, z
  where (x, y) elem pairs
    andalso (y, z) elem pairs
    andalso (z, x) elem pairs
  group {} compute count over ();
> val it = [366] : int bag

(* 3. 4-Clique -------------------------------------------------------
 * In Datalog:
 *   4Clique(x, y, z, w) :- R(x, y), S(y, z), T(x, z), U(x, w),
 *       V(y, w), Q(z, w).
 *)

from x, y, z, w
  where (x, y) elem western_pairs
    andalso (y, z) elem western_pairs
    andalso (x, z) elem western_pairs
    andalso (x, w) elem western_pairs
    andalso (y, w) elem western_pairs
    andalso (z, w) elem western_pairs
  order (w, x, y, z);
