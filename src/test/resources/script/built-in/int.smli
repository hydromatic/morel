 * Unit tests for the built-in `Int` structure, defined
 * by the Standard ML Basis Library.
 *)
Sys.set ("lineWidth", 78);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit

Int;
> val it =
>   {abs=fn,compare=fn,div=fn,fromInt=fn,fromLarge=fn,fromString=fn,max=fn,
>    maxInt=SOME 2147483647,min=fn,minInt=SOME ~2147483648,mod=fn,
>    precision=SOME 32,quot=fn,rem=fn,sameSign=fn,sign=fn,toInt=fn,toLarge=fn,
>    toString=fn}
>   : {abs:int -> int, compare:int * int -> order, div:int * int -> int,
>      fromInt:int -> int, fromLarge:int -> int, fromString:string -> int option,
>      max:int * int -> int, maxInt:int option, min:int * int -> int,
>      minInt:int option, mod:int * int -> int, precision:int option,
>      quot:int * int -> int, rem:int * int -> int, sameSign:int * int -> bool,
>      sign:int -> int, toInt:int -> int, toLarge:int -> int,
>      toString:int -> string}

Int.abs;
> val it = fn : int -> int
Int.abs 5;
> val it = 5 : int
5.abs ();
> val it = 5 : int
Int.abs ~3;
> val it = 3 : int
(~3).abs ();
> val it = 3 : int
Int.abs (valOf Int.minInt);
> uncaught exception Overflow
>   raised at: stdIn:1.1-1.26
Int.compare;
> val it = fn : int * int -> order
Int.compare (4, 3);
> val it = GREATER : order
4.compare 3;
> val it = GREATER : order
Int.`div`;
> val it = fn : int * int -> int
Int.`div` (14, 3);
> val it = 4 : int
Int.`div` (~14, 3);
> val it = ~5 : int
Int.`div` (14, ~3);
> val it = ~5 : int
Int.`div` (~14, ~3);
> val it = 4 : int
Int.`div` (0, ~3);
> val it = 0 : int
Int.fromInt;
> val it = fn : int -> int
Int.fromInt 3;
> val it = 3 : int
Int.fromLarge;
> val it = fn : int -> int
Int.fromLarge 3;
> val it = 3 : int
Int.fromString;
> val it = fn : string -> int option
Int.fromString "~345";
> val it = SOME ~345 : int option
Int.max;
> val it = fn : int * int -> int
Int.max (4, 3);
> val it = 4 : int
4.max 3;
> val it = 4 : int
Int.maxInt;
> val it = SOME 2147483647 : int option
Int.min;
> val it = fn : int * int -> int
Int.min (4, 3);
> val it = 3 : int
4.min 3;
> val it = 3 : int
Int.`mod`;
> val it = fn : int * int -> int
Int.`mod` (14, 3);
> val it = 2 : int
Int.`mod` (~14, 3);
> val it = 1 : int
Int.`mod` (14, ~3);
> val it = ~1 : int
Int.`mod` (~14, ~3);
> val it = ~2 : int
Int.`mod` (0, ~3);
> val it = 0 : int
Int.quot;
> val it = fn : int * int -> int
Int.quot (14, 3);
> val it = 4 : int
Int.quot (~14, 3);
> val it = ~4 : int
Int.quot (14, ~3);
> val it = ~4 : int
Int.quot (~14, ~3);
> val it = 4 : int
Int.quot (0, ~3);
> val it = 0 : int
Int.precision;
> val it = SOME 32 : int option
Int.rem;
> val it = fn : int * int -> int
Int.rem (14, 3);
> val it = 2 : int
Int.rem (~14, 3);
> val it = ~2 : int
Int.rem (14, ~3);
> val it = 2 : int
Int.rem (~14, ~3);
> val it = ~2 : int
Int.rem (0, ~3);
> val it = 0 : int
Int.sameSign;
> val it = fn : int * int -> bool
Int.sameSign (3, ~2);
> val it = false : bool
Int.sameSign (0, ~2);
> val it = false : bool
Int.sameSign (2, 345);
> val it = true : bool
Int.sameSign (0, 0);
> val it = true : bool
Int.sign;
> val it = fn : int -> int
Int.sign ~3;
> val it = ~1 : int
(~3).sign ();
> val it = ~1 : int
Int.toInt;
> val it = fn : int -> int
Int.toInt 3;
> val it = 3 : int
Int.toLarge;
> val it = fn : int -> int
Int.toLarge 3;
> val it = 3 : int
Int.toString;
> val it = fn : int -> string
Int.toString ~345;
> val it = "~345" : string
(~345).toString ();
> val it = "~345" : string

(*) End int.smli
