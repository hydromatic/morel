 *
 * Unit tests for the built-in `PP` structure, a Wadler-Leijen
 * pretty-printer.
 *)
Sys.set ("printLength", 999);
> val it = () : unit

(*) The whole structure.
PP;
> val it =
>   {align=fn,beside=fn,braces=fn,brackets=fn,cat=fn,empty=-,encloseSep=fn,
>    fillCat=fn,fillSep=fn,`group`=fn,hang=fn,hardLine=-,hcat=fn,hsep=fn,
>    indent=fn,line=-,lineBreak=-,nest=fn,parens=fn,punctuate=fn,render=fn,
>    sep=fn,softBreak=-,softLine=-,text=fn,vcat=fn,vsep=fn}
>   : {align:doc -> doc, beside:doc * doc -> doc, braces:doc -> doc,
>       brackets:doc -> doc, cat:doc list -> doc, empty:doc,
>       encloseSep:doc * doc * doc * doc list -> doc, fillCat:doc list -> doc,
>       fillSep:doc list -> doc, `group`:doc -> doc, hang:int * doc -> doc,
>       hardLine:doc, hcat:doc list -> doc, hsep:doc list -> doc,
>       indent:int * doc -> doc, line:doc, lineBreak:doc, nest:int * doc -> doc,
>       parens:doc -> doc, punctuate:doc * doc list -> doc list,
>       render:int * doc -> string, sep:doc list -> doc, softBreak:doc,
>       softLine:doc, text:string -> doc, vcat:doc list -> doc,
>       vsep:doc list -> doc}

(*) `text` builds a document; `render` lays it out.
PP.render (80, PP.text "hello");
> val it = "hello" : string

(*) `empty` renders as nothing.
PP.render (80, PP.empty);
> val it = "" : string

(*) `beside` places documents next to each other.
PP.render (80, PP.beside (PP.text "foo", PP.text "bar"));
> val it = "foobar" : string

(*) `hsep` separates with spaces.
PP.render (80, PP.hsep [PP.text "a", PP.text "b", PP.text "c"]);
> val it = "a b c" : string

(*) `vsep` separates with line breaks.
PP.render (80, PP.vsep [PP.text "a", PP.text "b", PP.text "c"]);
> val it = "a\nb\nc" : string

(*) `sep` is flat if it fits.
PP.render (80, PP.sep [PP.text "a", PP.text "b", PP.text "c"]);
> val it = "a b c" : string

(*) `sep` breaks if it does not fit.
PP.render (3, PP.sep [PP.text "aa", PP.text "bb"]);
> val it = "aa\nbb" : string

(*) `group` lays out on one line if it fits.
PP.render (80, PP.`group` (PP.vsep [PP.text "a", PP.text "b"]));
> val it = "a b" : string

(*) The same group breaks when the width is too small.
PP.render (1, PP.`group` (PP.vsep [PP.text "a", PP.text "b"]));
> val it = "a\nb" : string

(*) `nest` increases indentation after a line break.
PP.render (3,
  PP.nest (2, PP.vsep [PP.text "a", PP.text "b", PP.text "c"]));
> val it = "a\n  b\n  c" : string

(*) `cat` concatenates with no separator when flat.
PP.render (80, PP.cat [PP.text "a", PP.text "b", PP.text "c"]);
> val it = "abc" : string

(*) `fillSep` fills lines, breaking only when needed.
PP.render (5,
  PP.fillSep [PP.text "a", PP.text "b", PP.text "c", PP.text "d"]);
> val it = "a b c\nd" : string

(*) `punctuate` inserts a separator between documents.
PP.render (80,
  PP.hcat (PP.punctuate (PP.text ", ",
    [PP.text "a", PP.text "b", PP.text "c"])));
> val it = "a, b, c" : string

(*) `encloseSep` wraps a list between open and close.
PP.render (80,
  PP.encloseSep (PP.text "[", PP.text "]", PP.text ",",
    [PP.text "a", PP.text "b", PP.text "c"]));
> val it = "[a, b, c]" : string

(*) `parens`, `braces` and `brackets` enclose a document.
PP.render (80, PP.parens (PP.text "x"));
> val it = "(x)" : string
PP.render (80, PP.braces (PP.text "x"));
> val it = "{x}" : string
PP.render (80, PP.brackets (PP.text "x"));
> val it = "[x]" : string

(*) `indent` indents every line, including the first.
PP.render (80, PP.indent (4, PP.text "x"));
> val it = "    x" : string

(*) `hardLine` always breaks, even inside a group.
PP.render (80, PP.`group` (PP.hcat [PP.text "a", PP.hardLine, PP.text "b"]));
> val it = "a\nb" : string

(*) End pp.smli
