 *
 * Unit tests for the built-in `Bool` structure, defined
 * by the Standard ML Basis Library.
 *)
Sys.set ("lineWidth", 78);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit

Bool;
> val it = {fromString=fn,not=fn,toString=fn}
>   : {fromString:string -> bool option, not:bool -> bool,
>      toString:bool -> string}
Bool.fromString "true";
> val it = SOME true : bool option
Bool.fromString "false";
> val it = SOME false : bool option
Bool.fromString "yes";
> val it = NONE : bool option
Bool.toString true;
> val it = "true" : string
Bool.toString false;
> val it = "false" : string
false.toString ();
> val it = "false" : string
Bool.not true;
> val it = false : bool
true.not ();
> val it = false : bool
Bool.not false;
> val it = true : bool

(*) End bool.smli
