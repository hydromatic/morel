 *
 * Tests for inlining and other optimizations.
 *)
Sys.set ("stringDepth", ~1);
> val it = () : unit

(* --- Variable inlining ------------------------------------------ *)

(*) A variable used once is inlined.
let val x = 1 in x + 2 end;
> val it = 3 : int
Sys.plan ();
> val it = "apply2(fnValue Int.+, constant(1), constant(2))" : string

(*) A variable used twice is not inlined if non-atomic.
let val x = 1 + 1 in x + x end;
> val it = 4 : int
Sys.plan ();
> val it =
>   "let1(expCode apply2(fnValue Int.+, constant(1), constant(1)), resultCode apply2(fnValue Int.+, stack(offset 1, name x), stack(offset 1, name x)))"
>   : string

(*) An atomic variable (bound to a literal) used twice is inlined.
let val x = 5 in x + x end;
> val it = 10 : int
Sys.plan ();
> val it = "apply2(fnValue Int.+, constant(5), constant(5))" : string

(*) A dead variable (not used) is removed.
let val x = 1 val y = 2 in y end;
> val it = 2 : int
Sys.plan ();
> val it = "constant(2)" : string

(* --- Function inlining ------------------------------------------ *)

(*) A function applied once is inlined.
let val f = fn x => x + 1 in f 5 end;
> val it = 6 : int
Sys.plan ();
> val it = "apply2(fnValue Int.+, constant(5), constant(1))" : string

(* --- Singleton case inlining ------------------------------------ *)

(*) A singleton case with id pattern is inlined.
let val f = fn x => case x of y => y + 2 in f 3 end;
> val it = 5 : int
Sys.plan ();
> val it = "apply2(fnValue Int.+, constant(3), constant(2))" : string

(* --- Constant case inlining (issue #330) ------------------------ *)

(*) Case on a constant matching a literal pattern.
let val x = 2 in case x of 1 => "one" | 2 => "two" | _ => "large" end;
> val it = "two" : string
Sys.plan ();
> val it = "constant(two)" : string

(*) Case on a constant matching the first pattern.
let val x = 1 in case x of 1 => "one" | 2 => "two" | _ => "large" end;
> val it = "one" : string
Sys.plan ();
> val it = "constant(one)" : string

(*) Case on a constant matching the wildcard pattern.
let val x = 99 in case x of 1 => "one" | 2 => "two" | _ => "large" end;
> val it = "large" : string
Sys.plan ();
> val it = "constant(large)" : string

(*) Case on a constant with id pattern that binds the value.
let val x = 5 in case x of y => y + 10 end;
> val it = 15 : int
Sys.plan ();
> val it = "apply2(fnValue Int.+, constant(5), constant(10))" : string

(*) If-then-else with constant true condition.
if true then "yes" else "no";
> val it = "yes" : string
Sys.plan ();
> val it = "constant(yes)" : string

(*) If-then-else with constant false condition.
if false then "yes" else "no";
> val it = "no" : string
Sys.plan ();
> val it = "constant(no)" : string
Sys.planEx "~1";
> val it = "val it = case false of true => \"yes\" | _ => \"no\"" : string
Sys.planEx "1";
> val it = "val it = \"no\"" : string

(*) Boolean case.
let val b = true in case b of true => 1 | false => 0 end;
> val it = 1 : int
Sys.plan ();
> val it = "constant(1)" : string

(*) String case.
let val s = "hello" in case s of "hello" => 1 | "world" => 2 | _ => 3 end;
> val it = 1 : int
Sys.plan ();
> val it = "constant(1)" : string

(*) Char case.
let val c = #"a" in case c of #"a" => 1 | #"b" => 2 | _ => 3 end;
> val it = 1 : int
Sys.plan ();
> val it = "constant(1)" : string

(*) Real case.
let val r = 1.0 in case r of 0.0 => 0 | 1.0 => 1 | _ => 2 end;
> val it = 1 : int
Sys.planEx "1";
> val it = "val it = 1" : string

(*) Unit case.
let val u = () in case u of () => "unit" | _ => "not unit" end;
> stdIn:1.44-1.59 Error: match redundant
>   raised at: stdIn:1.44-1.59
Sys.planEx "1";
> val it = "val it = \"unit\"" : string

(*) Tuple case.
let
  val t = (1, "a")
in
  case t of
     (0, _) => "zero"
   | (1, s) => "one:" ^ s
   | _ => "other"
end;
> val it = "one:a" : string
Sys.planEx "~1";
> val it =
>   "val it = let val t = (1, \"a\") in case t of (0, _) => \"zero\" | (1, s) => \"one:\" ^ s | _ => \"other\" end"
>   : string
Sys.planEx "1";
> val it = "val it = #^ String (\"one:\", \"a\")" : string

(*) Record case.
let
  val t = {a = 1, b = "a"}
in
  case t of
     {a = 0, ...} => "zero"
   | {a = 1, b = s} => "one:" ^ s
   | _ => "other"
end;
> val it = "one:a" : string
Sys.planEx "~1";
> val it =
>   "val it = let val t = {a = 1, b = \"a\"} in case t of {a = 0, b = _} => \"zero\" | {a = 1, b = s} => \"one:\" ^ s | _ => \"other\" end"
>   : string
Sys.planEx "1";
> val it = "val it = #^ String (\"one:\", \"a\")" : string

(*) Enum case
let
  val ordering = LESS
in
  case ordering of
     LESS => "LESS"
   | GREATER => "GREATER"
   | _ => "?"
end;
> val it = "LESS" : string
Sys.planEx "~1";
> val it =
>   "val it = let val ordering = LESS in case ordering of LESS => \"LESS\" | GREATER => \"GREATER\" | _ => \"?\" end"
>   : string
Sys.planEx "1";
> val it = "val it = \"LESS\"" : string

(*) Option case (an enum with one argument).
let
  val someA = SOME "a"
in
  case someA of
      SOME "0" => "some0"
    | SOME s => "some:" ^ s
    | NONE => "none"
end;
> val it = "some:a" : string
Sys.planEx "~1";
> val it =
>   "val it = let val someA = SOME \"a\" in case someA of SOME(\"0\") => \"some0\" | SOME(s) => \"some:\" ^ s | NONE => \"none\" end"
>   : string
Sys.planEx "1";
> val it = "val it = #^ String (\"some:\", \"a\")" : string

let
  val none = NONE
in
  case none of
      SOME "0" => "some0"
    | SOME s => "some:" ^ s
    | NONE => "none"
end;
> val it = "none" : string
Sys.planEx "~1";
> val it =
>   "val it = let val none = NONE in case none of SOME(\"0\") => \"some0\" | SOME(s) => \"some:\" ^ s | NONE => \"none\" end"
>   : string
Sys.planEx "1";
> val it = "val it = \"none\"" : string

(*) Either case (an enum with two type parameters).
let
  val `left` = INL "a"
in
  case `left` of INL s => "left:" ^ s | INR s => "right:" ^ s
end;
> val it = "left:a" : string
Sys.planEx "~1";
> val it =
>   "val it = let val `left` = INL \"a\" in case `left` of INL(s) => \"left:\" ^ s | INR(s_1) => \"right:\" ^ s_1 end"
>   : string
Sys.planEx "1";
> val it = "val it = #^ String (\"left:\", \"a\")" : string

(*) Tree case (an enum with a tuple value)
let
  datatype tree = EMPTY | NODE of tree * int * string
  val v = NODE (NODE (EMPTY, 1, "a"), 2, "b")
in
  case v of EMPTY => "empty" | NODE (t, i, s) => s
end;
> val it = "b" : string
Sys.planEx "~1";
> val it =
>   "val it = local datatype tree in let val v = NODE (NODE (EMPTY, 1, \"a\"), 2, \"b\") in case v of EMPTY => \"empty\" | NODE((t, i, s)) => s end end"
>   : string
Sys.planEx "1";
> val it = "val it = local datatype tree in \"b\" end" : string

(* --- Cross-compile-unit inlining (issue #223) ------------------- *)

(*) An atomic integer from a previous compile unit is inlined.
val x = 42;
> val x = 42 : int
x + 1;
> val it = 43 : int
Sys.planEx "0";
> val it = "val it = 42 + 1" : string

(*) An atomic string from a previous compile unit is inlined.
val greeting = "hello";
> val greeting = "hello" : string
String.size greeting;
> val it = 5 : int
Sys.planEx "0";
> val it = "val it = #size String \"hello\"" : string

(*) An atomic boolean from a previous compile unit is inlined.
val flag = true;
> val flag = true : bool
if flag then 1 else 2;
> val it = 1 : int
Sys.planEx "2";
> val it = "val it = 1" : string

(*) Multiple atomic values from previous compile units are inlined.
val a = 10;
> val a = 10 : int
val b = 20;
> val b = 20 : int
a + b;
> val it = 30 : int
Sys.planEx "0";
> val it = "val it = 10 + 20" : string

(* --- Cross-compile-unit function inlining (issue #223) ---------- *)

(*) A simple function from a previous compile unit is inlined.
val inc = fn x => x + 1;
> val inc = fn : int -> int
inc 5;
> val it = 6 : int
Sys.planEx "3";
> val it = "val it = 5 + 1" : string

(*) A function with multiple operations is inlined and beta-reduced.
val double = fn n => n * 2;
> val double = fn : int -> int
double 7;
> val it = 14 : int
Sys.planEx "3";
> val it = "val it = #* Int (7, 2)" : string

(*) Composing inlined functions.
val inc2 = fn x => x + 1;
> val inc2 = fn : int -> int
val double2 = fn x => x * 2;
> val double2 = fn : int -> int
inc2 (double2 3);
> val it = 7 : int
Sys.planEx "3";
> val it = "val it = #* Int (3, 2) + 1" : string

fn i => inc2 (double2 i);
> val it = fn : int -> int
Sys.planEx "3";
> val it = "val it = fn i => #* Int (i, 2) + 1" : string

(*) Recursive functions are NOT inlined (would cause infinite expansion).
val rec factorial = fn n => if n < 2 then 1 else n * factorial (n - 1);
> val factorial = fn : int -> int
factorial 5;
> val it = 120 : int
Sys.planEx "0";
> val it = "val it = factorial 5" : string

(*) Polymorphic functions are NOT inlined (require type unification).
val id = fn x => x;
> val id = fn : 'a -> 'a
id 42;
> val it = 42 : int
Sys.planEx "0";
> val it = "val it = id 42" : string

(*) Functions that reference other inlinable values are also inlined.
val offset = 100;
> val offset = 100 : int
val addOffset = fn x => x + offset;
> val addOffset = fn : int -> int
addOffset 5;
> val it = 105 : int
Sys.planEx "3";
> val it = "val it = 5 + 100" : string

(*) Capture
val n = 1;
> val n = 1 : int
val f = fn x => x + n;
> val f = fn : int -> int
val n = 2;
> val n = 2 : int
(*) Result should be 4 = 3 + 1, because n = 1 when f captured it.
val i = f 3;
> val i = 4 : int
Sys.planEx "3";
> val it = "val i = 3 + 1" : string

(*) Predicate inversion in a graph query
val edges = [
 {x = 1, y = 2},
 {x = 2, y = 3}];
> val edges = [{x=1,y=2},{x=2,y=3}] : {x:int, y:int} list

fun edge (x, y) = {x, y} elem edges;
> val edge = fn : int * int -> bool

fun path (x, y) =
  edge (x, y)
  orelse (exists z where path (x, z) andalso edge (z, y));
> val path = fn : int * int -> bool

from p where path p;
> val it = [(1,2),(2,3),(1,3)] : (int * int) bag

(*) Adjacent range branches of orelse are merged into a single discreteSetOf.
from i where i > 0 andalso i < 10 orelse i > 12 andalso i <= 15;
> val it = [1,2,3,4,5,6,7,8,9,13,14,15] : int bag
Sys.planEx "1";
> val it =
>   "val it = from i in #fromList Bag (#flatten Range ([OPEN (0, 10), OPEN_CLOSED (12, 15)]))"
>   : string

(*) Point (i = v) and range branches are also merged.
from i where i = 1 orelse i > 5 andalso i < 8 orelse i = 3;
> val it = [1,3,6,7] : int bag
Sys.planEx "1";
> val it =
>   "val it = from i in #fromList Bag (#flatten Range ([POINT 1, OPEN (5, 8), POINT 3]))"
>   : string

(*) Char is a finite type (256 values), so the plan filters the extent directly.
from c where c >= #"a" andalso c <= #"e" orelse c >= #"x" andalso c <= #"z";
> val it = [#"a",#"b",#"c",#"d",#"e",#"x",#"y",#"z"] : char bag
Sys.planEx "1";
> val it =
>   "val it = from c in extent \"char\" where c >= #\"a\" andalso c <= #\"e\" orelse c >= #\"x\" andalso c <= #\"z\""
>   : string

(* --- FBBT (feasibility-based bound tightening) ---------------------
 * FBBT uses inequality conditions and tightens bounds to those that
 * could pass the filters (are 'feasible').
 *)

(* For abs, FBBT recognizes `abs x OP c` for the connected-interval
 * cases and emits the equivalent two-sided bounds. *)
from x where abs x < 5;
> val it = [~4,~3,~2,~1,0,1,2,3,4] : int bag
Sys.planEx "3";
> val it =
>   "val it = from x in #fromList Bag (#flatten Range ([OPEN (~5, 5)])) where #abs Int x < 5"
>   : string
from x where abs x <= 3;
> val it = [~3,~2,~1,0,1,2,3] : int bag
from x where 5 > abs x;
> val it = [~4,~3,~2,~1,0,1,2,3,4] : int bag
from x where abs x = 0;
> val it = [0] : int bag
from x where abs x < 10 andalso x > 0;
> val it = [1,2,3,4,5,6,7,8,9] : int bag
(*) Disjoint case (abs x > c) is two intervals — FBBT skips and the
(*) constraint cannot be inverted by the existing extractor either.
from x where abs x > 5;
> stdIn:1.6 Error: pattern 'x' is not grounded
>   raised at: stdIn:1.6

(* Strengthened bounds via a non-linear constraint. FBBT recognizes
 * `(varA + kA) * (varB + kB) OP c` and propagates one side's bounds to
 * the other (positive quadrant only). *)
Bag.length (from x, y where x >= 1 andalso y >= 1 andalso x * (y + 3) < 30);
> val it = 51 : int
Sys.planEx "3";
> val it =
>   "val it = #length Bag (from x in #fromList Bag (#flatten Range ([CLOSED (1, 7)])) join y in #fromList Bag (#flatten Range ([CLOSED_OPEN (1, 27)])) where #* Int (x, y + 3) < 30)"
>   : string

(* Same strengthening via the literal range-list syntax. FBBT injects
 * the implied lower bounds from `[1..]`, propagates through the
 * multiplication constraint, and pushes the deduced upper bounds back
 * into each scan's range constructor — turning `[1..]` into `[1..7]`
 * and `[1..^27]`. Preserves the original `int list` (ordered) type. *)
from x in [1..] where x < 5;
> val it = [1,2,3,4] : int list
List.length (from x in [1..], y in [1..] where x * (y + 3) < 30);
> val it = 51 : int
Sys.planEx "3";
> val it =
>   "val it = #length List (from x in #flatten Range ([CLOSED (1, 7)]) join y in #flatten Range ([CLOSED_OPEN (1, 27)]) where #* Int (x, y + 3) < 30)"
>   : string

(* RangePushdown also handles char-typed infinite range scans. *)
from c in [#"a"..] where c < #"e";
> val it = [#"a",#"b",#"c",#"d"] : char list
Sys.planEx "3";
> val it = "val it = from c in #flatten Range ([CLOSED_OPEN (#\"a\", #\"e\")])"
>   : string
from c in [#"a"..] where c <= #"d";
> val it = [#"a",#"b",#"c",#"d"] : char list

(* Cyclic bounds resolved by FBBT.
 *
 * Each variable's generator depends on another. FBBT propagates the
 * constants through the cycle to deduce constant bounds for each
 * variable: the deduced bounds let the extractor build a finite range
 * for each generator, and the original cross-variable predicates
 * (e.g. `x < y`) remain as post-generation filters. *)
Bag.length (from x, y where x > 0 andalso x < y andalso y < 10);
> val it = 36 : int
Sys.planEx "3";
> val it =
>   "val it = #length Bag (from x in #fromList Bag (#flatten Range ([OPEN (0, 10)])) join y in #fromList Bag (#flatten Range ([OPEN (0, 10)])) where x < y)"
>   : string
Bag.length (from x, y where y > 0 andalso y < x andalso x < 10);
> val it = 36 : int
Bag.length (from x, y, z where x > 0 andalso x < y andalso y < z andalso z < 10);
> val it = 84 : int
from x where x > 0 andalso x < x + 1 andalso x < 5;
> val it = [1,2,3,4] : int bag

(* Ranges that cannot be deduced even with FBBT.
 *
 * The first query is feasible but unbounded (`x < y andalso y < x + 10`
 * admits any x). The second has a non-linear constraint that needs
 * monotonicity reasoning. The third is a tilted polytope where the
 * variables only acquire bounds after pairs of constraints are added,
 * which is the job of Fourier-Motzkin elimination, not FBBT. All three
 * report 'not grounded' for now; subsequent techniques will handle
 * them. *)
from x, y where x < y andalso y < x + 10;
> stdIn:1.6 Error: pattern 'x' is not grounded
>   raised at: stdIn:1.6
from x, y where x > 0 andalso x * y = 100 andalso y > 0;
> stdIn:1.6 Error: pattern 'x' is not grounded
>   raised at: stdIn:1.6
from x, y
  where x + y >= 0 andalso x + y <= 10
  andalso x - y >= ~3 andalso x - y <= 3;
> stdIn:1.6 Error: pattern 'x' is not grounded
>   raised at: stdIn:1.6

(*) End optimize.smli
