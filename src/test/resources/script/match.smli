> val classify = fn : big * color -> string

fn (C01, RED) => "first"
  | (_, GREEN) => "green"
  | (_, BLUE) => "blue"
  | (_, RED) => "red";
> val classify = fn : big * color -> string

fun classify (C01, RED) = "first, red"
  | classify (C01, GREEN) = "first, green"
  | classify (C01, BLUE) = "first, blue"
  | classify (_, GREEN) = "green"
  | classify (_, BLUE) = "blue"
  | classify (_, RED) = "red"
  | classify (C01, _) = "first, other";
