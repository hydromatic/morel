Sys.set ("lineWidth", 78);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit

(*) Set properties for deterministic Date/Time tests.
Sys.set ("timeZone", "UTC");
> val it = () : unit
Sys.set ("now", "2024-01-01T00:00:00Z");
> val it = () : unit

(* Until we have a real "print" function, we use "ignore" to
   suppress the output of expressions. *)
fun print x = ignore x;
> val print = fn : 'a -> unit

(* Operators ------------------------------------------------------ *)

2 + 3;
> val it = 5 : int
2 + 3 * 4;
> val it = 14 : int
Sys.plan ();
> val it =
>   "apply2(fnValue Int.+, constant(2), apply2(fnValue Int.*, constant(3), constant(4)))"
>   : string
14 div 3;
> val it = 4 : int
14 div ~3;
> val it = ~5 : int

from (i, j) in [(14, 3), (~14, 3), (14, ~3), (~14, ~3)]
 where (i div j) <> Int.`div` (i, j)
 orelse (i mod j) <> Int.`mod` (i, j);
> val it = [] : {i:int, j:int} list

fn x => x + 1;
> val it = fn : int -> int
Sys.plan ();
> val it =
>   "match(x, apply2(fnValue Int.+, stack(offset 1, name x), constant(1)))"
>   : string

val nan = Real.posInf / Real.posInf;
> val nan = nan : real

(* Datatypes ------------------------------------------------------ *)

(*
 * The "option" datatype, declared as follows:
 *   datatype 'a option = NONE | SOME
 *)
SOME 1;
> val it = SOME 1 : int option
NONE;
> val it = NONE : 'a option
NONE = NONE;
> val it = true : bool
NONE = SOME 1;
> val it = false : bool
SOME "a" = NONE;
> val it = false : bool
SOME (SOME true);
> val it = SOME (SOME true) : bool option option
SOME (SOME [1,2,3]);
> val it = SOME (SOME [1,2,3]) : int list option option
SOME (SOME {a=1, b=true});
> val it = SOME (SOME {a=1,b=true}) : {a:int, b:bool} option option

(*
 * The "descending" datatype, declared as follows:
 *   datatype 'a descending = DESC of 'a;
 *)
DESC;
> val it = fn : 'a -> 'a descending
DESC 1;
> val it = DESC 1 : int descending
DESC (DESC "a");
> val it = DESC (DESC "a") : string descending descending

(* Top-level environment ---------------------------------------------
 * Standard ML makes a number of types, exceptions and values available
 * at the top level, without qualification. For example, "hd" can be used
 * as shorthand for "List.hd". The following are the top-level types,
 * exceptions and values, per the Standard ML Basis.
 *)

(* Types ---------------------------------------------------------- *)
(* "eqtype unit" maps to "General" *)
();
> val it = () : unit
(* "eqtype int" maps to "Int" *)
0;
> val it = 0 : int
(* "eqtype word" maps to "Word" *)
0w0;
> val it = 0wx0 : word
(* "type real" maps to "Real" *)
1.5;
> val it = 1.5 : real
(* "eqtype char" maps to "Char" *)
#"a";
> val it = #"a" : char
(* "eqtype string" maps to "String" *)
"x";
> val it = "x" : string
(* "type substring" maps to "Substring" *)
(*) TODO substring
(* "type exn" maps to "General" *)
Empty;
> val it = Empty : exn
(* "eqtype 'a array" maps to "Array" *)
(*) TODO 'a array
(* "eqtype 'a vector" maps to "Vector" *)
Vector.fromList [1];
> val it = #[1] : int vector
(* "eqtype 'a ref" is primitive *)
(*) TODO 'a ref
(* "datatype bool = false | true" is primitive *)
true;
> val it = true : bool
(* "datatype 'a option = NONE | SOME of 'a" maps to "Option" *)
NONE;
> val it = NONE : 'a option
(* "datatype order = LESS | EQUAL | GREATER" maps to "General" *)
LESS;
> val it = LESS : order
(* "datatype 'a list = nil | :: of ('a * 'a list)" is primitive *)
[];
> val it = [] : 'a list

(* Exceptions ----------------------------------------------------- *)
(* "exception Bind" maps to "General" *)
Bind;
> val it = Bind : exn
(* "exception Chr" maps to "General" *)
Chr;
> val it = Chr : exn
(* "exception Div" maps to "General" *)
Div;
> val it = Div : exn
(* "exception Domain" maps to "General" *)
Domain;
> val it = Domain : exn
(* "exception Empty" maps to "List" *)
Empty;
> val it = Empty : exn
(* "exception Fail of string" maps to "General" *)
Fail "x";
> val it = Fail "x" : exn
(* "exception Match" maps to "General" *)
Match;
> val it = Match : exn
(* "exception Option" maps to "Option". The structure "Option" shadows the
 * exception, so we reach it via "valOf", which raises it. *)
valOf NONE;
> uncaught exception Option
>   raised at: stdIn:1.1-1.11
(* "exception Overflow" maps to "General" *)
Overflow;
> val it = Overflow : exn
(* "exception Size" maps to "General" *)
Size;
> val it = Size : exn
(* "exception Span" maps to "General" *)
Span;
> val it = Span : exn
(* "exception Subscript" maps to "General" *)
Subscript;
> val it = Subscript : exn

(* Values --------------------------------------------------------- *)

(* "val ! : 'a ref -> 'a" maps to "General.!" *)
(*) TODO !;

(* "val := : 'a ref * 'a -> unit" maps to "General.:=" *)
(*) TODO :=;

(* "val ~ : int -> int" maps to "Int.~"; overloaded for real *)
op ~;
> val it = fn : int -> int
Int.`~`;
> val it = fn : int -> int
~ 5;
> val it = ~5 : int
~ 3.5;
> val it = ~3.5 : real

(* "val + : int * int -> int" maps to "Int.+" *)
op +;
> val it = fn : int * int -> int
Int.`+`;
> val it = fn : int * int -> int

(* "val - : int * int -> int" maps to "Int.-" *)
op -;
> val it = fn : int * int -> int
Int.`-`;
> val it = fn : int * int -> int

(* "val * : int * int -> int" maps to "Int.*" *)
op *;
> val it = fn : int * int -> int
Int.`*`;
> val it = fn : int * int -> int

(* "val @ : ('a list * 'a list) -> 'a list" maps to "List.@" *)
op @;
> val it = fn : 'a list * 'a list -> 'a list
List.`@`;
> val it = fn : 'a list * 'a list -> 'a list

(* "val ^ : string * string -> string" maps to "String.^" *)
op ^;
> val it = fn : string * string -> string
String.`^`;
> val it = fn : string * string -> string

(* "val abs : int -> int" maps to "Int.abs"; overloaded for real *)
abs;
> val it = fn : 'a -> 'a
Int.abs;
> val it = fn : int -> int
abs ~3;
> val it = 3 : int
abs (valOf Int.minInt);
> uncaught exception Overflow [overflow]
>   raised at: stdIn:1.1-1.22
abs ~3.5;
> val it = 3.5 : real

(* "val app : ('a -> unit) -> 'a list -> unit" maps to "List.app" *)
app;
> val it = fn : ('a -> unit) -> 'a list -> unit
List.app;
> val it = fn : ('a -> unit) -> 'a list -> unit

(* "val before : 'a * unit -> 'a" maps to "General.before" *)
before;
> val it = fn : 'a * unit -> 'a
General.before;
> val it = fn : 'a * unit -> 'a

(* "val ceil : real -> int" maps to "Real.ceil" *)
ceil;
> val it = fn : real -> int
Real.ceil;
> val it = fn : real -> int

(* "val chr : int -> char" maps to "Char.chr" *)
chr;
> val it = fn : int -> char
Char.chr;
> val it = fn : int -> char

(* "val compare : 'a * 'a -> order" maps to "String.compare" *)
String.compare;
> val it = fn : string * string -> order
String.compare ("abc", "xyz");
> val it = LESS : order
String.compare ("abc", "");
> val it = GREATER : order

(* "val concat : string list -> string" maps to "String.concat" *)
concat;
> val it = fn : string list -> string
String.concat;
> val it = fn : string list -> string

(* "val exnMessage : exn -> string" maps to "General.exnMessage" *)
exnMessage;
> val it = fn : exn -> string
General.exnMessage;
> val it = fn : exn -> string

(* "val exnName : exn -> string" maps to "General.exnName" *)
exnName;
> val it = fn : exn -> string
General.exnName;
> val it = fn : exn -> string

(* "val explode : string -> char list" maps to "String.explode" *)
explode;
> val it = fn : string -> char list
String.explode;
> val it = fn : string -> char list

(* "val floor : real -> int" maps to "Real.floor" *)
floor;
> val it = fn : real -> int
Real.floor;
> val it = fn : real -> int

(* "val foldl : ('a*'b->'b)-> 'b -> 'a list -> 'b" maps to "List.foldl" *)
foldl;
> val it = fn : ('a * 'b -> 'b) -> 'b -> 'a list -> 'b
List.foldl;
> val it = fn : ('a * 'b -> 'b) -> 'b -> 'a list -> 'b

(* "val foldr : ('a*'b->'b)-> 'b -> 'a list -> 'b" maps to "List.foldr" *)
foldr;
> val it = fn : ('a * 'b -> 'b) -> 'b -> 'a list -> 'b
List.foldr;
> val it = fn : ('a * 'b -> 'b) -> 'b -> 'a list -> 'b

(* "val getOpt : ('a option * 'a) -> 'a" maps to "Option.getOpt" *)
getOpt;
> val it = fn : 'a option * 'a -> 'a
Option.getOpt;
> val it = fn : 'a option * 'a -> 'a

(* "val hd : 'a list -> 'a" maps to "List.hd" *)
hd;
> val it = fn : 'a list -> 'a
List.hd;
> val it = fn : 'a list -> 'a

(* "val ignore : 'a -> unit" maps to "General.ignore" *)
ignore;
> val it = fn : 'a -> unit
General.ignore;
> val it = fn : 'a -> unit

(* "val implode : char list -> string" maps to "String.implode" *)
implode;
> val it = fn : char list -> string
String.implode;
> val it = fn : char list -> string

(* "val isSome : 'a option -> bool" maps to "Option.isSome" *)
isSome;
> val it = fn : 'a option -> bool
Option.isSome;
> val it = fn : 'a option -> bool

(* "val length : 'a list -> int" maps to "List.length" *)
length;
> val it = fn : 'a list -> int
List.length;
> val it = fn : 'a list -> int

(* "val map : ('a -> 'b) -> 'a list -> 'b list" maps to "List.map" *)
map;
> val it = fn : ('a -> 'b) -> 'a list -> 'b list
List.map;
> val it = fn : ('a -> 'b) -> 'a list -> 'b list

(* "val not : bool -> bool" maps to "Bool.not" *)
not;
> val it = fn : bool -> bool
Bool.not;
> val it = fn : bool -> bool

(* "val null : 'a list -> bool" maps to "List.null" *)
null;
> val it = fn : 'a list -> bool
List.null;
> val it = fn : 'a list -> bool

(* "val o : ('a->'b) * ('c->'a) -> 'c->'b" maps to "General.o" *)
op o;
> val it = fn : ('a -> 'b) * ('c -> 'a) -> 'c -> 'b
`o`;
> val it = fn : ('a -> 'b) * ('c -> 'a) -> 'c -> 'b
General.`o`;
> val it = fn : ('a -> 'b) * ('c -> 'a) -> 'c -> 'b

(* "val ord : char -> int" maps to "Char.ord" *)
ord;
> val it = fn : char -> int
Char.ord;
> val it = fn : char -> int

