(* Morel-specific values ------------------------------------------ *)
(* The following top-level values are Morel extensions, not part of the
 * Standard ML basis library. Like the standard aliases above, each is an alias
 * for a value in a structure and resolves to the same value. *)

(* "bag" is a Morel alias for "Bag.fromList". *)
bag;
> val it = fn : 'a list -> 'a bag
Bag.fromList;
> val it = fn : 'a list -> 'a bag

(* "compare" is a Morel alias for "Relational.compare". (Standard ML has no
 * top-level "compare"; comparison is per-structure, e.g. "String.compare".) *)
compare;
> val it = fn : 'a * 'a -> order
Relational.compare;
> val it = fn : 'a * 'a -> order

(* "count" is a Morel alias for "Relational.count". *)
count;
> val it = fn : 'a bag -> int
Relational.count;
> val it = fn : 'a bag -> int

(* "empty" is a Morel alias for "Relational.empty". *)
empty;
> val it = fn : 'a bag -> bool
Relational.empty;
> val it = fn : 'a bag -> bool

(* "env" is a Morel alias for "Sys.env". *)
env;
> val it = fn : unit -> (string * string) list
Sys.env;
> val it = fn : unit -> (string * string) list

(* "fields" is a Morel alias for "String.fields". *)
fields;
> val it = fn : (char -> bool) -> string -> string list
String.fields;
> val it = fn : (char -> bool) -> string -> string list

(* "iterate" is a Morel alias for "Relational.iterate". *)
iterate;
> val it = fn : 'a list -> ('a list * 'a list -> 'a list) -> 'a list
Relational.iterate;
> val it = fn : 'a bag -> ('a bag * 'a bag -> 'a bag) -> 'a bag

(* "max" is a Morel alias for "Relational.max". *)
max;
> val it = fn : 'a bag -> 'a
Relational.max;
> val it = fn : 'a bag -> 'a

(* "min" is a Morel alias for "Relational.min". *)
min;
> val it = fn : 'a bag -> 'a
Relational.min;
> val it = fn : 'a bag -> 'a

(* "nonEmpty" is a Morel alias for "Relational.nonEmpty". *)
nonEmpty;
> val it = fn : 'a bag -> bool
Relational.nonEmpty;
> val it = fn : 'a bag -> bool

(* "only" is a Morel alias for "Relational.only". *)
only;
> val it = fn : 'a list -> 'a
Relational.only;
> val it = fn : 'a bag -> 'a

(* "plan" is a Morel alias for "Sys.plan". *)
plan;
> val it = fn : unit -> string
Sys.plan;
> val it = fn : unit -> string

(* "set" is a Morel alias for "Sys.set". *)
set;
> val it = fn : string * 'a -> unit
Sys.set;
> val it = fn : string * 'a -> unit

(* "show" is a Morel alias for "Sys.show". *)
show;
> val it = fn : string -> string option
Sys.show;
> val it = fn : string -> string option

(* "showAll" is a Morel alias for "Sys.showAll". *)
showAll;
> val it = fn : unit -> (string * string option) list
Sys.showAll;
> val it = fn : unit -> (string * string option) list

(* "tokens" is a Morel alias for "String.tokens". *)
tokens;
> val it = fn : (char -> bool) -> string -> string list
String.tokens;
> val it = fn : (char -> bool) -> string -> string list

(* "unset" is a Morel alias for "Sys.unset". *)
unset;
> val it = fn : string -> unit
Sys.unset;
> val it = fn : string -> unit

(* "useSilently" is a Morel alias for "Interact.useSilently". *)
useSilently;
> val it = fn : string -> unit
Interact.useSilently;
> val it = fn : string -> unit

(* Overloaded operators ------------------------------------------- *)
(* Standard ML overloads twelve operators. Each is shown with its default
 * signature, then applied to a value of each type for which it is defined.
 * Word arithmetic ("+", "-", "*", "div", "mod", "~") wraps modulo
 * 2^wordSize, and word division and comparison are unsigned. *)

(* "op +" : numeric (int, real, word); default "int * int -> int". *)
op +;
> val it = fn : int * int -> int
1 + 2;
> val it = 3 : int
1.0 + 2.0;
> val it = 3 : real
0wx8 + 0w9;
> val it = 0wx11 : word

(* "op -" : numeric (int, real, word). *)
op -;
> val it = fn : int * int -> int
3 - 1;
> val it = 2 : int
3.0 - 1.0;
> val it = 2 : real
0w3 - 0w1;
> val it = 0wx2 : word

(* "op *" : numeric (int, real, word). *)
op *;
> val it = fn : int * int -> int
2 * 3;
> val it = 6 : int
2.0 * 3.0;
> val it = 6 : real
0w2 * 0w3;
> val it = 0wx6 : word

(* "op div" : wordint (int, word). Word division is unsigned. *)
op div;
> val it = fn : int * int -> int
7 div 2;
> val it = 3 : int
0w17 div 0w5;
> val it = 0wx3 : word
0wxffffffffffffffff div 0w2;
> val it = 0wx7FFFFFFFFFFFFFFF : word

(* "op mod" : wordint (int, word). *)
op mod;
> val it = fn : int * int -> int
7 mod 2;
> val it = 1 : int
0w17 mod 0w5;
> val it = 0wx2 : word

(* "op /" : real only; applying to int is a type error. *)
op /;
> val it = fn : real * real -> real
3.0 / 2.0;
> val it = 1.5 : real
3 / 2;
> stdIn:1.1-1.6 Error: Cannot deduce type: conflict: int vs real
>   raised at: stdIn:1.1-1.6

(* "op ~" : num (int, real, word). For word, '~' is the 2's complement. *)
op ~;
> val it = fn : int -> int
~ 5;
> val it = ~5 : int
~ 5.0;
> val it = ~5 : real
~ 0w1;
> val it = 0wxFFFFFFFFFFFFFFFF : word

(* "abs" : a function (not an operator), numeric (int, real). *)
abs;
> val it = fn : 'a -> 'a
abs ~5;
> val it = 5 : int
abs ~5.0;
> val it = 5 : real

(* "op <" : numtext (int, real, string, char, word). Word is unsigned, so a
 * word with the high bit set is large. *)
op <;
> val it = fn : 'a * 'a -> bool
1 < 2;
> val it = true : bool
1.0 < 2.0;
> val it = true : bool
"a" < "b";
> val it = true : bool
#"a" < #"b";
> val it = true : bool
0w1 < 0w2;
> val it = true : bool
0wxffffffffffffffff < 0w1;
> val it = false : bool

(* "op >" : numtext (int, real, string, char, word). *)
op >;
> val it = fn : 'a * 'a -> bool
2 > 1;
> val it = true : bool
2.0 > 1.0;
> val it = true : bool
"b" > "a";
> val it = true : bool
#"b" > #"a";
> val it = true : bool
0wxffffffffffffffff > 0w1;
> val it = true : bool

(* "op <=" : numtext (int, real, string, char, word). *)
op <=;
> val it = fn : 'a * 'a -> bool
2 <= 2;
> val it = true : bool
2.0 <= 2.0;
> val it = true : bool
"a" <= "a";
> val it = true : bool
#"a" <= #"a";
> val it = true : bool
0w7 <= 0w7;
> val it = true : bool

(* "op >=" : numtext (int, real, string, char, word). *)
op >=;
> val it = fn : 'a * 'a -> bool
2 >= 3;
> val it = false : bool
2.0 >= 3.0;
> val it = false : bool
"a" >= "b";
> val it = false : bool
#"a" >= #"b";
> val it = false : bool
0wx8000000000000000 >= 0w1;
> val it = true : bool

(*) End built-in.smli
