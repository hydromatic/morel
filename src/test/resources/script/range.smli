 *
 * Tests for the Range structure.
 *)

(* Range structure *)
Range;
> val it =
>   {complement=fn,contains=fn,continuousSetOf=fn,discreteSetOf=fn,flatten=fn,
>    ranges=fn,toBag=fn,toList=fn}
>   : {complement:'a continuous_set -> 'a continuous_set,
>       contains:'b range -> 'b -> bool,
>       continuousSetOf:'c range list -> 'c continuous_set,
>       discreteSetOf:'d range list -> 'd discrete_set,
>       flatten:'e range list -> 'e list,
>       ranges:'f continuous_set -> 'f range list,
>       toBag:'g discrete_set -> 'g bag, toList:'h discrete_set -> 'h list}

(*) Constructors.
POINT 5 : int range;
> val it = POINT 5 : int range

AT_LEAST 3 : int range;
> val it = AT_LEAST 3 : int range

GREATER_THAN 3 : int range;
> val it = GREATER_THAN 3 : int range

AT_MOST 10 : int range;
> val it = AT_MOST 10 : int range

LESS_THAN 10 : int range;
> val it = LESS_THAN 10 : int range

CLOSED (3, 7) : int range;
> val it = CLOSED (3,7) : int range

OPEN (3, 7) : int range;
> val it = OPEN (3,7) : int range

CLOSED_OPEN (3, 7) : int range;
> val it = CLOSED_OPEN (3,7) : int range

OPEN_CLOSED (3, 7) : int range;
> val it = OPEN_CLOSED (3,7) : int range

ALL : int range;
> val it = ALL : int range

(*) contains on int ranges: interior, boundary, exterior.
Range.contains (CLOSED (3, 7)) 5;
> val it = true : bool

Range.contains (CLOSED (3, 7)) 3;
> val it = true : bool

Range.contains (CLOSED (3, 7)) 2;
> val it = false : bool

(*) contains with open bounds.
Range.contains (OPEN (3, 7)) 5;
> val it = true : bool

Range.contains (OPEN (3, 7)) 3;
> val it = false : bool

(*) contains with POINT.
Range.contains (POINT 5) 5;
> val it = true : bool

Range.contains (POINT 5) 4;
> val it = false : bool

(*) contains with ALL.
Range.contains ALL 5;
> val it = true : bool

Range.contains ALL ~999;
> val it = true : bool

(*) contains with unbounded ranges.
Range.contains (AT_LEAST 3) 5;
> val it = true : bool

Range.contains (AT_LEAST 3) 2;
> val it = false : bool

Range.contains (AT_MOST 7) 5;
> val it = true : bool

Range.contains (AT_MOST 7) 8;
> val it = false : bool

Range.contains (GREATER_THAN 3) 4;
> val it = true : bool

Range.contains (GREATER_THAN 3) 3;
> val it = false : bool

Range.contains (LESS_THAN 7) 6;
> val it = true : bool

Range.contains (LESS_THAN 7) 7;
> val it = false : bool

(*) Postfix (method) syntax, with explicit outer parens.
(CLOSED (3, 7)).contains 5;
> val it = true : bool

(* Postfix syntax without outer parens: "CTOR arg.method" parses as
 * "(CTOR arg).method", not "CTOR (arg.method)". *)
CLOSED (3, 7).contains 5;
> val it = true : bool

(*) contains on char ranges.
Range.contains (CLOSED (#"a", #"z")) #"e";
> val it = true : bool

Range.contains (CLOSED (#"a", #"z")) #"E";
> val it = false : bool

(*) contains on bool * DESC int ranges (exotic element type).
Range.contains (CLOSED ((false, DESC 5), (false, DESC 3))) (false, DESC 4);
> val it = true : bool

Range.contains (CLOSED ((false, DESC 5), (false, DESC 3))) (false, DESC 6);
> val it = false : bool

(*) ALL subsumes all other ranges.
Range.continuousSetOf [ALL, CLOSED (1, 3)];
> val it = CONTINUOUS_SET [ALL] : int continuous_set

(*) ALL as the only range.
Range.continuousSetOf [ALL : int range];
> val it = CONTINUOUS_SET [ALL] : int continuous_set

(*) continuousSetOf normalizes a list of ranges into a continuous_set.
Range.continuousSetOf [CLOSED (5, 10), CLOSED (1, 3), CLOSED (3, 6)];
> val it = CONTINUOUS_SET [CLOSED (1,10)] : int continuous_set

(*) Non-overlapping ranges are kept separate.
Range.continuousSetOf [CLOSED (1, 3), CLOSED (7, 9)];
> val it = CONTINUOUS_SET [CLOSED (1,3),CLOSED (7,9)] : int continuous_set

(*) Touching ranges where upper is inclusive, lower is exclusive: (1,3] and (3,6] merge to (1,6].
Range.continuousSetOf [OPEN_CLOSED (1, 3), OPEN_CLOSED (3, 6)];
> val it = CONTINUOUS_SET [OPEN_CLOSED (1,6)] : int continuous_set

(*) Touching ranges where both are exclusive: (1,3) and (3,6] do not merge (gap at 3).
Range.continuousSetOf [OPEN (1, 3), OPEN_CLOSED (3, 6)];
> val it = CONTINUOUS_SET [OPEN (1,3),OPEN_CLOSED (3,6)] : int continuous_set

(*) Chain merge: three ranges [1,4], [4,7], [6,9] merge into [1,9], and 8 is subsumed.
Range.continuousSetOf [CLOSED (1, 4), POINT 0, CLOSED (6, 9), POINT 8, POINT 10, CLOSED (4, 7)];
> val it = CONTINUOUS_SET [POINT 0,CLOSED (1,9),POINT 10]
>   : int continuous_set

(*) Ranges do not merge because the domain is discrete.
Range.continuousSetOf [CLOSED (1, 3), POINT 0, POINT 8, CLOSED (4, 7)];
> val it = CONTINUOUS_SET [POINT 0,CLOSED (1,3),CLOSED (4,7),POINT 8]
>   : int continuous_set

(*) Three ranges where the first two merge, third stays separate.
Range.continuousSetOf [CLOSED (1, 4), CLOSED (3, 7), CLOSED (20, 25)];
> val it = CONTINUOUS_SET [CLOSED (1,7),CLOSED (20,25)] : int continuous_set

(*) Three ranges where first stays separate, last two merge.
Range.continuousSetOf [CLOSED (1, 3), CLOSED (6, 8), CLOSED (7, 10)];
> val it = CONTINUOUS_SET [CLOSED (1,3),CLOSED (6,10)] : int continuous_set

(*) Three ranges producing two separate groups.
Range.continuousSetOf [CLOSED (1, 3), CLOSED (2, 5), CLOSED (8, 10)];
> val it = CONTINUOUS_SET [CLOSED (1,5),CLOSED (8,10)] : int continuous_set

(*) ALL subsumes all other ranges in a discrete_set.
Range.discreteSetOf [ALL, CLOSED (1, 3)];
> val it = DISCRETE_SET [ALL] : int discrete_set

(*) discreteSetOf normalizes a list of ranges into a discrete_set.
Range.discreteSetOf [CLOSED (5, 10), CLOSED (1, 3), CLOSED (3, 6)];
> val it = DISCRETE_SET [CLOSED (1,10)] : int discrete_set

(*) Adjacent discrete ranges are merged: [1,3] and [4,7] become [1,7].
Range.discreteSetOf [CLOSED (1, 3), CLOSED (4, 7)];
> val it = DISCRETE_SET [CLOSED (1,7)] : int discrete_set

(*) Three discrete ranges producing two groups.
Range.discreteSetOf [CLOSED (1, 3), CLOSED (4, 6), CLOSED (10, 12)];
> val it = DISCRETE_SET [CLOSED (1,6),CLOSED (10,12)] : int discrete_set

(*) Chain merge: three ranges each extending the boundary merge into [0,8].
Range.discreteSetOf [CLOSED (1, 3), POINT 0, CLOSED (7, 8), POINT 10, CLOSED (4, 7)];
> val it = DISCRETE_SET [CLOSED (0,8),POINT 10] : int discrete_set

(*) discreteSetOf requires a discrete element type; string is not discrete.
Range.discreteSetOf [CLOSED ("a", "z")];
> 0.0-0.0 Error: not a discrete type: string
>   raised at: 0.0-0.0

(*) real is not discrete.
Range.discreteSetOf [CLOSED (1.0, 3.0)];
> 0.0-0.0 Error: not a discrete type: real
>   raised at: 0.0-0.0

(*) A tuple containing a non-discrete component is not discrete.
Range.discreteSetOf [CLOSED ((false, "a"), (true, "z"))];
> 0.0-0.0 Error: not a discrete type: string
>   raised at: 0.0-0.0

(*) contains on continuous_set (postfix syntax).
val cs = Range.continuousSetOf [CLOSED (1, 3), CLOSED (7, 9)];
> val cs = CONTINUOUS_SET [CLOSED (1,3),CLOSED (7,9)] : int continuous_set

cs.contains 2;
> val it = true : bool

cs.contains 5;
> val it = false : bool

(* Boundary and corner cases for set contains (exercises binary search).
 * Before first range. *)
cs.contains 0;
> val it = false : bool

(*) Inclusive lower boundary.
cs.contains 1;
> val it = true : bool

(*) Inclusive upper boundary.
cs.contains 3;
> val it = true : bool

(*) In gap between ranges.
cs.contains 5;
> val it = false : bool

(*) Inclusive lower boundary of second range.
cs.contains 7;
> val it = true : bool

(*) After last range.
cs.contains 10;
> val it = false : bool

(*) Empty continuous_set contains nothing.
(Range.continuousSetOf []).contains 5;
> val it = false : bool

(*) Exclusive boundary (OPEN range): endpoint is not a member.
val csOpen = Range.continuousSetOf [OPEN (1, 5), OPEN (7, 9)];
> val csOpen = CONTINUOUS_SET [OPEN (1,5),OPEN (7,9)] : int continuous_set

csOpen.contains 1;
> val it = false : bool

csOpen.contains 2;
> val it = true : bool

csOpen.contains 5;
> val it = false : bool

(*) Unbounded lower (AT_MOST): values below bound are members.
(Range.continuousSetOf [AT_MOST 3, AT_LEAST 7]).contains 2;
> val it = true : bool

(Range.continuousSetOf [AT_MOST 3, AT_LEAST 7]).contains 5;
> val it = false : bool

(Range.continuousSetOf [AT_MOST 3, AT_LEAST 7]).contains 8;
> val it = true : bool

(*) contains on discrete_set (postfix syntax).
val ds = Range.discreteSetOf [CLOSED (1, 3), CLOSED (7, 9)];
> val ds = DISCRETE_SET [CLOSED (1,3),CLOSED (7,9)] : int discrete_set

ds.contains 2;
> val it = true : bool

ds.contains 5;
> val it = false : bool

(*) ranges returns the list of ranges in a continuous_set.
cs.ranges ();
> val it = [CLOSED (1,3),CLOSED (7,9)] : int range list

(*) toList enumerates values of a discrete_set in ascending order.
(Range.discreteSetOf [CLOSED (5, 10)]).toList ();
> val it = [5,6,7,8,9,10] : int list

(Range.discreteSetOf [OPEN (5, 10)]).toList ();
> val it = [6,7,8,9] : int list

(Range.discreteSetOf [POINT 5]).toList ();
> val it = [5] : int list

(Range.discreteSetOf [CLOSED (1, 3), CLOSED (7, 9)]).toList ();
> val it = [1,2,3,7,8,9] : int list

(*) toList on char ranges.
(Range.discreteSetOf [CLOSED (#"a", #"e")]).toList ();
> val it = [#"a",#"b",#"c",#"d",#"e"] : char list

(*) toList on bool * bool (exotic element type).
(Range.discreteSetOf [CLOSED ((false, false), (true, true))]).toList ();
> val it = [(false,false),(false,true),(true,false),(true,true)] : (bool * bool) list

(*) toList on bool * DESC int.
(Range.discreteSetOf [CLOSED ((false, DESC 3), (false, DESC 1))]).toList ();
> val it = [(false,DESC 3),(false,DESC 2),(false,DESC 1)]
>   : (bool * int descending) list

(*) toBag enumerates values as a bag.
(Range.discreteSetOf [CLOSED (1, 3)]).toBag ();
> val it = [1,2,3] : int bag

(*) complement of a continuous_set.
(Range.continuousSetOf [CLOSED (1.0, 3.0), CLOSED (7.0, 9.0)]).complement ();
> val it = CONTINUOUS_SET [LESS_THAN 1,OPEN (3,7),GREATER_THAN 9]
>   : real continuous_set

(*) complement of a continuous_set with open bounds.
val cs = Range.continuousSetOf [OPEN (1.0, 3.0), AT_LEAST 7.0];
> val cs = CONTINUOUS_SET [OPEN (1,3),AT_LEAST 7] : real continuous_set

cs.contains 2.0;
> val it = true : bool

cs.contains 1.0;
> val it = false : bool

cs.contains 8.5;
> val it = true : bool

cs.complement ();
> val it = CONTINUOUS_SET [AT_MOST 1,CLOSED_OPEN (3,7)] : real continuous_set

(*) complement of ALL is empty; complement of empty is ALL.
(Range.continuousSetOf [ALL : real range]).complement ();
> val it = CONTINUOUS_SET [] : real continuous_set

(Range.continuousSetOf [] : real continuous_set).complement ();
> val it = CONTINUOUS_SET [ALL] : real continuous_set

(*) double complement.
cs.complement ().complement ();
> val it = CONTINUOUS_SET [OPEN (1,3),AT_LEAST 7] : real continuous_set

(*) complement of a discrete_set.
(Range.discreteSetOf [CLOSED (1, 3), CLOSED (7, 9)]).complement ();
> val it = DISCRETE_SET [AT_MOST 0,CLOSED (4,6),AT_LEAST 10] : int discrete_set

(*) complement of discrete_set with OPEN bounds.
(Range.discreteSetOf [OPEN (3, 7)]).complement ();
> val it = DISCRETE_SET [AT_MOST 3,AT_LEAST 7] : int discrete_set

(*) discrete double complement is identity.
val ds = Range.discreteSetOf [CLOSED (1, 3), CLOSED (7, 9)];
> val ds = DISCRETE_SET [CLOSED (1,3),CLOSED (7,9)] : int discrete_set

ds.complement ().complement ();
> val it = DISCRETE_SET [CLOSED (1,3),CLOSED (7,9)] : int discrete_set

(*) discrete_set from 3 ranges, then toList.
val evens = Range.discreteSetOf [CLOSED (0, 2), CLOSED (4, 6), CLOSED (8, 10)];
> val evens = DISCRETE_SET [CLOSED (0,2),CLOSED (4,6),CLOSED (8,10)]
>   : int discrete_set

evens.toList ();
> val it = [0,1,2,4,5,6,8,9,10] : int list

(*) toList on (order, bool) either enumerates all 5 values.
val eitherSet = Range.discreteSetOf [CLOSED (INL LESS, INR true)];
> val eitherSet = DISCRETE_SET [CLOSED (INL LESS,INR true)]
>   : (order,bool) either discrete_set

eitherSet.toList ();
> val it = [INL (LESS),INL (EQUAL),INL (GREATER),INR false,INR true]
>   : (order,bool) either list

(*) Apply f to each value in the set.
fun f (INL LESS) = 1 | f (INR true) = 1 | f _ = 0;
> val f = fn : (order,bool) either -> int

List.map f (eitherSet.toList ());
> val it = [1,0,0,0,1] : int list

(* Range.flatten -------------------------------------------------- *)

(*) flatten concatenates the ranges, preserving order and duplicates.
Range.flatten [CLOSED (0, 3), POINT 10, CLOSED (2, 5)];
> val it = [0,1,2,3,10,2,3,4,5] : int list

(*) flatten on a single CLOSED range.
Range.flatten [CLOSED (1, 5)];
> val it = [1,2,3,4,5] : int list

(*) flatten preserves duplicate POINTs.
Range.flatten [POINT 1, POINT 2, POINT 1, POINT 3];
> val it = [1,2,1,3] : int list

(*) flatten on an empty list.
Range.flatten ([] : int range list);
> val it = [] : int list

(* Range list syntax ---------------------------------------------- *)

(*) Plain list literal: no ranges, unchanged.
[1, 2, 3];
> val it = [1,2,3] : int list

(*) CLOSED.
[1 .. 5];
> val it = [1,2,3,4,5] : int list

(*) CLOSED_OPEN.
[1 ..^ 5];
> val it = [1,2,3,4] : int list

(*) OPEN_CLOSED.
[1 ^.. 5];
> val it = [2,3,4,5] : int list

(*) OPEN.
[1 ^..^ 5];
> val it = [2,3,4] : int list

(*) Singleton range = POINT becomes ordinary list literal.
[5];
> val it = [5] : int list

(*) Mixed POINTs and ranges.
[1 .. 5, 10];
> val it = [1,2,3,4,5,10] : int list

(*) Multiple ranges; duplicates are preserved.
[0..3, 10, 2..5, 10];
> val it = [0,1,2,3,10,2,3,4,5,10] : int list

(*) char ranges.
[#"a" .. #"e"];
> val it = [#"a",#"b",#"c",#"d",#"e"] : char list

(*) bool range.
[false .. true];
> val it = [false,true] : bool list

(* Bag variant: `bag` is a regular function, so the range syntax works
 * inside its argument. *)
bag [0 .. 5, 10];
> val it = [0,1,2,3,4,5,10] : int bag

(* Lexer disambiguation between `^` (string concat) and the new tokens. *)

(*) Plain `^` is string concatenation.
"a" ^ "b";
> val it = "ab" : string

(*) Plain comparison in a where clause.
from x in [1, 2, 3] where x < 2;
> val it = [1] : int list

(*) `^..^` between values: OPEN.
[1 ^..^ 5];
> val it = [2,3,4] : int list

(*) Whitespace insensitivity.
[1^..^5];
> val it = [2,3,4] : int list

[1^..5];
> val it = [2,3,4,5] : int list

[1..^5];
> val it = [1,2,3,4] : int list

(* Comparison expressions as range operands (parens required;
 * bool ranges enumerate `false, true`). *)
[(1 < 2) .. (3 < 4)];
> val it = [true] : bool list

[(1 < 2) .. (3 > 4)];
> val it = [] : bool list

(*) List of bool comparisons: no `..` involved, plain list literal.
[1 < 2, 3 < 4, 5 < 6];
> val it = [true,true,true] : bool list

(* Infinite forms (runtime error) --------------------------------- *)

(*) AT_LEAST is unbounded above; enumeration raises Size.
[5 ..] : int list;
> uncaught exception Size [size]
>   raised at: 0.0-0.0

(*) Similar for GREATER_THAN.
[5 ^..] : int list;
> uncaught exception Size [size]
>   raised at: 0.0-0.0

(* Membership in infinite range-lists ----------------------------- *)

(*) Unbounded discrete range: AT_LEAST.
5 elem [0..];
> val it = true : bool

~3 elem [0..];
> val it = false : bool

5 notelem [0..];
> val it = false : bool

~3 notelem [0..];
> val it = true : bool

(*) Unbounded discrete range: LESS_THAN.
0 elem [..^ 5];
> val it = true : bool

10 elem [..^ 5];
> val it = false : bool

(*) ALL: any value of the element type belongs.
#"c" elem [..];
> val it = true : bool

(*) Continuous range over real.
5.5 elem [0.0 .. 10.0];
> val it = true : bool

15.0 elem [0.0 .. 10.0];
> val it = false : bool

(*) Endpoint inclusion follows the operator.
5 elem [0 ..^ 5];
> val it = false : bool

5 elem [0 ^.. 5];
> val it = true : bool

(*) Mixed bounded + unbounded items.
5 elem [0..3, 10..];
> val it = false : bool

12 elem [0..3, 10..];
> val it = true : bool

(*) String range (continuous-style; non-POINT ranges allowed for elem).
"b" elem ["a" ..^ "z"];
> val it = true : bool

(* Non-discrete element type -------------------------------------- *)

(*) POINT items over real are finite.
[1.0];
> val it = [1] : real list

[1.0, 2.5, 1.0];
> val it = [1,2.5,1] : real list

Range.flatten [POINT 1.0, POINT 3.0, POINT 1.0];
> val it = [1,3,1] : real list

(*) Non-POINT ranges over real are infinite.
[0.0 .. 1.0];
> uncaught exception Size [size]
>   raised at: 0.0-0.0

(*) Same for string.
["a"];
> val it = ["a"] : string list

["a" .. "z"];
> uncaught exception Size [size]
>   raised at: 0.0-0.0

(*) End range.smli
